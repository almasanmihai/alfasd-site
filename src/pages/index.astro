---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import ProjectCard from '../components/ProjectCard.astro';
import CtaBand from '../components/CtaBand.astro';
import { getCollection } from 'astro:content';
import { site } from '../site.config';

const projects = (await getCollection('projects'))
  .filter((p) => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const title = site.name;
const description =
  'Proiectare structuri de rezistență, expertize tehnice autorizate A1/A2 și consultanță. București și la nivel național. Peste 500 de proiecte din 2006.';
---

<Layout {title} {description}>
  <section class="relative overflow-hidden bg-slate-900">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-amber-500/15 via-transparent to-transparent"
      aria-hidden="true"
    />
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
      <p class="text-sm font-semibold uppercase tracking-widest text-amber-400">
        Inginerie structurală
      </p>
      <h1
        class="mt-4 max-w-3xl font-display text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl"
      >
        Structuri sigure și eficiente, proiectate pentru performanță.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-relaxed text-slate-300">
        Proiectăm structuri, dar construim parteneriate — de la rezidențial la proiecte speciale, cu
        documentații clare și respect pentru termene.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href="/contact"
          class="inline-flex rounded-xl bg-amber-500 px-6 py-3.5 text-sm font-semibold text-slate-900 shadow-lg transition hover:bg-amber-400"
        >
          Solicită ofertă
        </a>
        <a
          href="/portofoliu"
          class="inline-flex rounded-xl border border-white/20 bg-white/5 px-6 py-3.5 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/10"
        >
          Explorează portofoliul
        </a>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-10 lg:grid-cols-3">
      <article class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="font-display text-xl font-semibold text-slate-900">Proiectare</h2>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Proiecte pentru structuri de rezistență: civile, industriale și agricole. Soluții sigure,
          eficiente și adaptate arhitecturii.
        </p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="font-display text-xl font-semibold text-slate-900">Expertizare</h2>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Expertize tehnice autorizate în domeniile A1 și A2 — evaluări precise și recomandări
          fundamentate.
        </p>
      </article>
      <article class="rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <h2 class="font-display text-xl font-semibold text-slate-900">Consultanță</h2>
        <p class="mt-3 text-slate-600 leading-relaxed">
          Suport tehnic în proiectare și execuție — de la idee până la recepția construcției.
        </p>
      </article>
    </div>
  </section>

  <section class="border-y border-slate-200 bg-slate-50 py-16 lg:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionTitle
        eyebrow="Principiile noastre"
        title="Calitate, fezabilitate și termene respectate"
        subtitle="Ne ghidăm după aceleași standarde, indiferent de anvergura proiectului: soluții adaptate, costuri optimizate, suport până la recepție."
      />
      <ul class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          'Soluții adaptate cerințelor arhitecturale',
          'Conformitate cu codurile de proiectare',
          'Optimizare pentru bugetul de investiție',
          'Termene respectate cu strictețe',
          'Răspuns rapid la probleme de șantier',
          'Prețuri corecte, aliniate pieței'
        ].map((item) => (
          <li class="flex gap-3 rounded-xl bg-white p-4 shadow-sm ring-1 ring-slate-200/80">
            <span class="mt-0.5 text-amber-600" aria-hidden="true">✓</span>
            <span class="text-slate-700">{item}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="flex flex-col gap-8 sm:flex-row sm:items-end sm:justify-between">
      <SectionTitle
        eyebrow="Portofoliu"
        title="Proiecte selectate"
        subtitle="Exemple anonimizate din activitatea noastră — înlocuiți imaginile cu fotografiile dumneavoastră (fără date sensibile în cadru)."
      />
      <a
        href="/portofoliu"
        class="shrink-0 text-sm font-semibold text-amber-700 hover:underline"
      >
        Tot portofoliul →
      </a>
    </div>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <ProjectCard project={p} />
      ))}
    </div>
  </section>

  <section class="border-t border-slate-200 bg-white py-16 lg:py-20">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionTitle
        eyebrow="Recomandări"
        title="Ce spun colaboratorii"
        align="center"
      />
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        <figure class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
          <blockquote class="text-slate-700 leading-relaxed">
            <p>
              „Firma serioasă, lucrează profesionist, nu te lasă în drum. Toate colaborările cu ei au
              fost duse la bun sfârșit cu succes.”
            </p>
          </blockquote>
          <figcaption class="mt-6">
            <p class="font-semibold text-slate-900">arh. Cezar Cozma</p>
            <p class="text-sm text-slate-600">Manager, Saco Proiect</p>
          </figcaption>
        </figure>
        <figure class="rounded-2xl border border-slate-200 bg-slate-50 p-8">
          <blockquote class="text-slate-700 leading-relaxed">
            <p>
              „Profesionalism, promptitudine, calitate, optimizare, open-minded — printre puținii
              structuriști adevărați.”
            </p>
          </blockquote>
          <figcaption class="mt-6">
            <p class="font-semibold text-slate-900">arh. Traian Neacșu</p>
            <p class="text-sm text-slate-600">Arhitect</p>
          </figcaption>
        </figure>
      </div>
    </div>
  </section>

  <div class="pb-20">
    <CtaBand />
  </div>
</Layout>
