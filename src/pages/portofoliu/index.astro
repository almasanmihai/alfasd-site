---
import Layout from '../../layouts/Layout.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import PortfolioFilters from '../../components/PortfolioFilters.astro';
import CtaBand from '../../components/CtaBand.astro';
import { getCollection } from 'astro:content';

const title = 'Portofoliu';
const description =
  'Proiecte de proiectare structuri de rezistență — rezidențial, educațional și altele. Exemple anonimizate; imagini pot fi adăugate în public/images/projects.';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order || a.data.title.localeCompare(b.data.title)
);
---

<Layout {title} {description}>
  <div class="border-b border-slate-200 bg-slate-50 py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionTitle
        eyebrow="Lucrări"
        title="Structuri diverse, proiecte de succes"
        subtitle="Detalii fără identificatori sensibili. Adăugați fotografii în fișierele Markdown (câmpurile cover și gallery) după ce verificați că nu apar nume de clienți, plăcuțe sau numere de înmatriculare."
      />
      <div class="mt-10">
        <PortfolioFilters />
      </div>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <ProjectCard project={p} />
      ))}
    </div>
  </div>

  <div class="pb-20">
    <CtaBand />
  </div>
</Layout>
