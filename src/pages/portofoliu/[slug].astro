---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { publicAssetPath } from '../../lib/publicPath';
import { resolveProjectMedia } from '../../lib/scanProjectMedia';

export async function getStaticPaths() {
  const items = await getCollection('projects');
  return items.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/i, '') },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, category, typology, year, region, materials } = entry.data;
const { cover, gallery } = resolveProjectMedia(entry.data);

const pageTitle = title;
const description = `${typology}. ${region ? region + '. ' : ''}Proiect anonimizat — Alfa Structural Design.`;
const coverSrc = cover ? publicAssetPath(cover) : '';
const gallerySrc = gallery.map((src) => publicAssetPath(src));
---

<Layout title={pageTitle} description={description} image={cover || undefined}>
  <article class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8 lg:py-16">
    <nav class="text-sm text-slate-500" aria-label="Breadcrumb">
      <a href="/portofoliu" class="hover:text-amber-700">Portofoliu</a>
      <span class="mx-2" aria-hidden="true">/</span>
      <span class="text-slate-800">{title}</span>
    </nav>

    <header class="mt-6">
      <span
        class="inline-block rounded-full bg-amber-50 px-3 py-1 text-xs font-semibold capitalize text-amber-900 ring-1 ring-amber-200"
      >
        {category}
      </span>
      <h1 class="mt-4 font-display text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        {title}
      </h1>
      <p class="mt-2 text-lg text-slate-600">{typology}</p>
      {(year || region) && (
        <p class="mt-4 text-sm text-slate-500">
          {year && <span>{year}</span>}
          {year && region && <span> · </span>}
          {region && <span>{region}</span>}
        </p>
      )}
    </header>

    {cover && (
      <figure class="mt-10 overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 shadow-sm">
        <img src={coverSrc} alt="" class="w-full object-cover" loading="eager" />
      </figure>
    )}

    <div class="prose prose-slate mt-10 max-w-none prose-headings:font-display prose-a:text-amber-700">
      <Content />
    </div>

    {materials?.length ? (
      <div class="mt-10">
        <h2 class="font-display text-lg font-semibold text-slate-900">Materiale / sisteme</h2>
        <ul class="mt-3 flex flex-wrap gap-2">
          {materials.map((m) => (
            <li class="rounded-lg bg-slate-100 px-3 py-1 text-sm font-medium text-slate-800">{m}</li>
          ))}
        </ul>
      </div>
    ) : null}

    {gallerySrc.length > 0 && (
      <div class="mt-12">
        <h2 class="font-display text-lg font-semibold text-slate-900">Galerie</h2>
        <div class="mt-4 grid gap-4 sm:grid-cols-2">
          {gallerySrc.map((src) => (
            <img
              src={src}
              alt=""
              class="rounded-xl border border-slate-200 object-cover"
              loading="lazy"
            />
          ))}
        </div>
      </div>
    )}

    <p class="mt-12 rounded-xl bg-slate-50 p-4 text-sm text-slate-600 ring-1 ring-slate-200/80">
      Proiect prezentat în mod anonimizat, fără identificarea beneficiarului sau a adresei exacte.
    </p>

    <a
      href="/portofoliu"
      class="mt-8 inline-flex text-sm font-semibold text-amber-700 hover:underline"
    >
      ← Înapoi la portofoliu
    </a>
  </article>
</Layout>
