---
import Layout from '../layouts/Layout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import CtaBand from '../components/CtaBand.astro';

const title = 'Servicii';
const description =
  'Proiectare structuri de rezistență, expertize tehnice A1/A2, consolidări și consultanță tehnică. Alfa Structural Design, București.';
---

<Layout {title} {description}>
  <div class="border-b border-slate-200 bg-slate-50 py-14">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <SectionTitle
        eyebrow="Ce oferim"
        title="Servicii de inginerie structurală"
        subtitle="De la concept la detalii de execuție — livrăm documentații clare, verificabile și aliniate normativelor în vigoare."
      />
    </div>
  </div>

  <div class="mx-auto max-w-6xl space-y-16 px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
    <section class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900">Proiectare structuri</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">
          Proiectare pentru construcții civile, industriale și agricole: beton armat, metal, lemn sau
          soluții mixte. Calcul structural, detaliere, optimizare pentru execuție și cost.
        </p>
      </div>
      <ul class="space-y-3 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Memoriu tehnic și calcule justificative
        </li>
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Planșe și detalii pentru execuție
        </li>
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Asistență la clarificări de șantier
        </li>
      </ul>
    </section>

    <section class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900">Expertizare tehnică</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">
          Evaluarea stării tehnice a construcțiilor existente și stabilirea măsurilor necesare,
          inclusiv în domeniile autorizate A1 și A2.
        </p>
      </div>
      <ul class="space-y-3 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Rapoarte structurate, cu concluzii clare
        </li>
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Recomandări pentru intervenții / consolidări
        </li>
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Suport în relația cu autoritățile și verificatori
        </li>
      </ul>
    </section>

    <section class="grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <h2 class="font-display text-2xl font-bold text-slate-900">Consultanță</h2>
        <p class="mt-4 text-slate-600 leading-relaxed">
          Consiliere în fază de concept, fezabilitate tehnică, alegerea soluției structurale și
          coordonare cu arhitectură și instalații.
        </p>
      </div>
      <ul class="space-y-3 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Analiză opțiuni structurale
        </li>
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Estimări de efort și risc tehnic
        </li>
        <li class="flex gap-2 text-slate-700">
          <span class="text-amber-600">•</span> Suport până la recepția lucrărilor
        </li>
      </ul>
    </section>
  </div>

  <div class="pb-20">
    <CtaBand />
  </div>
</Layout>
