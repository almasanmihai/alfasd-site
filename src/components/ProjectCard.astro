---
import type { CollectionEntry } from 'astro:content';
import { publicAssetPath } from '../lib/publicPath';
import { resolveProjectMedia } from '../lib/scanProjectMedia';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { title, category, typology, region, year, materials, tags } = project.data;
const { cover } = resolveProjectMedia(project.data);
const slug = project.id.replace(/\.md$/i, '');
const href = `/portofoliu/${slug}`;
const coverSrc = cover ? publicAssetPath(cover) : '';
---

<article
  class="project-card group flex flex-col overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm transition hover:border-amber-300/60 hover:shadow-md"
  data-category={category}
  data-tags={tags.join(',')}
>
  <a href={href} class="block focus:outline-none focus-visible:ring-2 focus-visible:ring-amber-500">
    <div class="relative aspect-[4/3] bg-slate-200">
      {cover ? (
        <img
          src={coverSrc}
          alt=""
          class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.02]"
          loading="lazy"
        />
      ) : (
        <div
          class="flex h-full w-full flex-col items-center justify-center bg-gradient-to-br from-slate-800 to-slate-900 p-6 text-center"
          aria-hidden="true"
        >
          <span class="font-display text-sm font-semibold uppercase tracking-widest text-amber-400"
            >Structură</span
          >
          <span class="mt-2 text-xs text-slate-300">Adăugați fotografie în folderul public</span>
        </div>
      )}
      <span
        class="absolute left-3 top-3 rounded-full bg-white/95 px-2.5 py-1 text-xs font-semibold text-slate-800 shadow-sm capitalize"
      >
        {category}
      </span>
    </div>
    <div class="flex flex-1 flex-col p-5">
      <h2 class="font-display text-lg font-semibold text-slate-900 group-hover:text-amber-800">
        {title}
      </h2>
      <p class="mt-1 text-sm text-slate-600">{typology}</p>
      {(year || region) && (
        <p class="mt-3 text-xs text-slate-500">
          {year && <span>{year}</span>}
          {year && region && <span> · </span>}
          {region && <span>{region}</span>}
        </p>
      )}
      <ul class="mt-4 flex flex-wrap gap-1.5">
        {materials.slice(0, 4).map((m) => (
          <li class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">{m}</li>
        ))}
      </ul>
      <span
        class="mt-4 inline-flex items-center text-sm font-semibold text-amber-700 group-hover:underline"
      >
        Vezi detalii
        <span class="ml-1" aria-hidden="true">→</span>
      </span>
    </div>
  </a>
</article>
