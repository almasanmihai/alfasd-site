---
import { site } from '../site.config';

const year = new Date().getFullYear();
---

<footer class="border-t border-slate-200 bg-slate-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-3">
      <div>
        <p class="font-display text-lg font-semibold text-brand-900">{site.legalName}</p>
        <p class="mt-2 max-w-sm text-sm leading-relaxed text-slate-600">
          Proiectare structuri de rezistență, expertize tehnice și consultanță — soluții sigure,
          fezabile și aliniate codurilor de proiectare.
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold text-brand-900">Contact</p>
        <ul class="mt-3 space-y-2 text-sm text-slate-600">
          <li>
            <a href={`tel:${site.phoneTel}`} class="hover:text-amber-700">{site.phone}</a>
          </li>
          <li>
            <a href={`mailto:${site.email}`} class="hover:text-amber-700">{site.email}</a>
          </li>
          <li class="pt-1 leading-relaxed">
            {site.address.street}<br />
            {site.address.city}, {site.address.country}
          </li>
          <li class="text-slate-500">{site.hours}</li>
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-brand-900">Pagini</p>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href="/servicii" class="text-slate-600 hover:text-amber-700">Servicii</a></li>
          <li><a href="/portofoliu" class="text-slate-600 hover:text-amber-700">Portofoliu</a></li>
          <li><a href="/despre" class="text-slate-600 hover:text-amber-700">Despre noi</a></li>
          <li><a href="/contact" class="text-slate-600 hover:text-amber-700">Contact</a></li>
        </ul>
        <ul class="mt-4 flex flex-wrap gap-x-4 gap-y-2 text-xs text-slate-500">
          <li><a href="/termeni-si-conditii" class="hover:text-slate-700">Termeni și condiții</a></li>
          <li>
            <a href="/politica-de-confidentialitate" class="hover:text-slate-700"
              >Politica de confidențialitate</a
            >
          </li>
        </ul>
      </div>
    </div>
    <p class="mt-10 border-t border-slate-200 pt-8 text-center text-xs text-slate-500">
      © {year} {site.legalName}. Toate drepturile rezervate.
    </p>
  </div>
</footer>
