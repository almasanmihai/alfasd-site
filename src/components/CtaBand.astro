---
interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = 'Aveți nevoie de structură de rezistență sau expertiză?',
  subtitle = 'Trimiteți detalii despre proiect — revenim rapid cu recomandări și o ofertă.'
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
  <div
    class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 px-8 py-12 text-center shadow-xl sm:px-12"
  >
    <div
      class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-amber-500/20 blur-3xl"
      aria-hidden="true"
    />
    <div
      class="pointer-events-none absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-amber-400/10 blur-3xl"
      aria-hidden="true"
    />
    <h2 class="relative font-display text-2xl font-bold text-white sm:text-3xl">{title}</h2>
    <p class="relative mx-auto mt-4 max-w-2xl text-slate-300">{subtitle}</p>
    <div class="relative mt-8 flex flex-wrap items-center justify-center gap-4">
      <a
        href="/contact"
        class="inline-flex rounded-xl bg-amber-500 px-6 py-3 text-sm font-semibold text-slate-900 shadow-lg transition hover:bg-amber-400"
      >
        Solicită ofertă
      </a>
      <a
        href="/portofoliu"
        class="inline-flex rounded-xl border border-white/25 bg-white/5 px-6 py-3 text-sm font-semibold text-white backdrop-blur transition hover:bg-white/10"
      >
        Vezi portofoliu
      </a>
    </div>
  </div>
</section>
